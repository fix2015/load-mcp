{
  "name": "load-mcp",
  "version": "1.0.0",
  "description": "CLI tool to discover, search, and install MCP (Model Context Protocol) servers for Claude Code, Cursor, and other AI tools",
  "main": "src/index.js",
  "bin": {
    "load-mcp": "bin/load-mcp.js"
  },
  "scripts": {
    "start": "node bin/load-mcp.js",
    "scrape": "node src/scraper/index.js",
    "test": "node --test test/**/*.test.js",
    "lint": "eslint src/ bin/ test/",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "cursor",
    "ai-tools",
    "mcp-servers",
    "cli",
    "developer-tools",
    "coding-assistant"
  ],
  "author": "fix2015",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fix2015/load-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/fix2015/load-mcp/issues"
  },
  "homepage": "https://github.com/fix2015/load-mcp#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "data/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "ora": "^5.4.1",
    "node-fetch": "^2.7.0",
    "cli-table3": "^0.6.3",
    "fuzzy": "^0.1.3"
  },
  "devDependencies": {
    "eslint": "^8.56.0"
  }
}
